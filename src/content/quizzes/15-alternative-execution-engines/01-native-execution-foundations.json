      "starterCode": "from pyspark.sql import SparkSession\nfrom pyspark.sql import functions as F\n\nspark = SparkSession.builder.appName(\"native-exec-benchmark\").getOrCreate()\n\ndata = [\n    (\"HashAggregate\", 12.5, 3.1),\n    (\"SortMergeJoin\", 18.2, 7.8),\n    (\"Filter+Project\", 4.3, 1.2),\n    (\"WindowFunction\", 9.7, 4.5),\n    (\"ColumnarShuffle\", 15.0, 5.0),\n]\nschema = [\"operation\", \"jvm_time_sec\", \"native_time_sec\"]\n\ndf = spark.createDataFrame(data, schema)\n\n# TODO: \u0414\u043e\u0431\u0430\u0432\u044c\u0442\u0435 \u043a\u043e\u043b\u043e\u043d\u043a\u0443 speedup_ratio = jvm_time_sec / native_time_sec\n# \u041e\u043a\u0440\u0443\u0433\u043b\u0438\u0442\u0435 \u0434\u043e 2 \u0437\u043d\u0430\u043a\u043e\u0432 \u043f\u043e\u0441\u043b\u0435 \u0437\u0430\u043f\u044f\u0442\u043e\u0439\n\n# TODO: \u041e\u0442\u0441\u043e\u0440\u0442\u0438\u0440\u0443\u0439\u0442\u0435 \u043f\u043e speedup_ratio \u043f\u043e \u0443\u0431\u044b\u0432\u0430\u043d\u0438\u044e\n\n# TODO: \u0412\u044b\u0432\u0435\u0434\u0438\u0442\u0435 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442 \u0447\u0435\u0440\u0435\u0437 show()\n",
      "solutionCode": "from pyspark.sql import SparkSession\nfrom pyspark.sql import functions as F\n\nspark = SparkSession.builder.appName(\"native-exec-benchmark\").getOrCreate()\n\ndata = [\n    (\"HashAggregate\", 12.5, 3.1),\n    (\"SortMergeJoin\", 18.2, 7.8),\n    (\"Filter+Project\", 4.3, 1.2),\n    (\"WindowFunction\", 9.7, 4.5),\n    (\"ColumnarShuffle\", 15.0, 5.0),\n]\nschema = [\"operation\", \"jvm_time_sec\", \"native_time_sec\"]\n\ndf = spark.createDataFrame(data, schema)\n\nresult = df.withColumn(\n    \"speedup_ratio\",\n    F.round(F.col(\"jvm_time_sec\") / F.col(\"native_time_sec\"), 2)\n).orderBy(F.col(\"speedup_ratio\").desc())\n\nresult.show()",
