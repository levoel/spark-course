      "solutionCode": "from pyspark.sql import SparkSession\nfrom pyspark.sql import functions as F\n\nspark = SparkSession.builder.appName(\"gluten-comparison\").getOrCreate()\n\ndata = [\n    (\"scan\", \"velox\", 2500000),\n    (\"scan\", \"clickhouse\", 2200000),\n    (\"filter\", \"velox\", 3100000),\n    (\"filter\", \"clickhouse\", 3400000),\n    (\"aggregate\", \"velox\", 1800000),\n    (\"aggregate\", \"clickhouse\", 2100000),\n    (\"join\", \"velox\", 950000),\n    (\"join\", \"clickhouse\", 870000),\n    (\"sort\", \"velox\", 1200000),\n    (\"sort\", \"clickhouse\", 1150000),\n]\nschema = [\"operation\", \"backend\", \"rows_per_sec\"]\n\ndf = spark.createDataFrame(data, schema)\n\npivoted = df.groupBy(\"operation\").pivot(\"backend\").agg(F.first(\"rows_per_sec\"))\n\nresult = pivoted.withColumn(\n    \"winner\",\n    F.when(F.col(\"velox\") > F.col(\"clickhouse\"), \"velox\").otherwise(\"clickhouse\")\n).orderBy(\"operation\")\n\nresult.show()",
